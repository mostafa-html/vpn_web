# ─────────────────────────────────────────────────────────────────────────
# vShop – Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────

# ── Django core ─────────────────────────────────────────────────────────────
# Generate a new key with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-very-secret-key-here

DEBUG=False

# Comma-separated list of allowed hosts (no spaces)
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Database (optional – defaults to SQLite if not set) ────────────────────
# Uncomment and set for PostgreSQL in production:
# DATABASE_URL=postgresql://user:password@db:5432/vshop
